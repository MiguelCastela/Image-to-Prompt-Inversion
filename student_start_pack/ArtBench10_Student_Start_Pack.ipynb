      "id": "03de3ee9",
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Exported 500 images to: exported_data/train_subset/images\n",
            "Metadata CSV: exported_data/train_subset/metadata.csv\n"
